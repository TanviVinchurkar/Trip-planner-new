# ──────────────────────────────────────────────
#  Trip Planner - Environment Variables
#  Copy this file to .env and fill in your values
# ──────────────────────────────────────────────

PORT=5000

# MongoDB Atlas (free tier) - https://cloud.mongodb.com
# Create a free cluster → get your connection string
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/tripplanner?retryWrites=true&w=majority

# JWT secret - any long random string works for college project
JWT_SECRET=tripplanner_super_secret_key_2024

# OpenWeatherMap (free) - https://openweathermap.org/api
# Sign up → API Keys → copy your key
OPENWEATHER_API_KEY=your_openweather_key_here

# Unsplash (free) - https://unsplash.com/developers
# Create app → copy Access Key
UNSPLASH_ACCESS_KEY=a7EvJVewNaxv7hA5w0Tbi5rEjkN16crI8aG7yHW9dCQ

# Google Gemini (free) - https://aistudio.google.com
# Sign in → Get API Key → copy it
GEMINI_API_KEY=AIzaSyAIvQ2sYrcqmrfOZUdg94uhGE44vkZcQhk

# Frontend URL (for CORS)
CLIENT_URL=http://127.0.0.1:5500
